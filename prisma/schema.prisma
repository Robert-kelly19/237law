generator client {
  provider = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

model LawSection {
  id            String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  lawName       String
  articleNumber String
  content       String
  source        String
  content_hash  String
  embedding     Unsupported("vector(1536)")

  @@map("law_sections")
}